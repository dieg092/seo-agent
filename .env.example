# Neon — rama seo-agent, rol limitado al schema seo_agent (Task 2)
DATABASE_URL=
DIRECT_URL=

# Service account de Google con acceso de lectura a GSC + GA4 (Task 4)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Pega la clave privada completa (incluye -----BEGIN PRIVATE KEY-----),
# sustituyendo los saltos de línea reales por \n literales en una sola línea.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# miwebdeboda.com está verificado en Search Console como propiedad de dominio,
# no de URL con prefijo — de ahí el formato sc-domain: (confirmado con
# searchconsole.sites.list() contra la service account real).
GSC_SITE_URL=sc-domain:miwebdeboda.com
GA4_PROPERTY_ID=
SITE_BASE_URL=https://miwebdeboda.com

# PageSpeed Insights API key (API key simple, no OAuth) — proyecto miwebdeboda-seo-agent
PAGESPEED_API_KEY=

# Fine-grained PAT scoped ONLY a wedding-invite-2 (Contents + Pull requests:
# Read and write, nada más). Crear en
# https://github.com/settings/personal-access-tokens/new
WEDDING_INVITE_2_PAT=
GITHUB_REPO_OWNER=dieg092
GITHUB_REPO_NAME=wedding-invite-2
